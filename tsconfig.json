{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "bundler"
  },
  "include": [
    "src/**/*",
    "application/**/*",
    "infrastructure/**/*",
    "interfaces/**/*",
    "shared/**/*",
    "prisma.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
