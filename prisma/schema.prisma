generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String   // hash da senha (nunca salvar em texto puro)
  carts     Cart[]
  coupons   Coupon[] // cupons que o usuário pode usar
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float    // preço atual do produto
  imageUrl    String?
  stock       Int      @default(0) // quantidade em estoque
  category    String?
  cartItems   CartItem[]
  variations  ProductVariation[] // variações (cor, tamanho, etc)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Variação de produto (ex: "Camiseta Azul M", "Camiseta Vermelha G")
model ProductVariation {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String   // ex: "Azul - Tamanho M"
  price     Float    // preço pode ser diferente da variação
  stock     Int      @default(0)
  cartItems CartItem[]
  createdAt DateTime @default(now())
}

model Cart {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  isActive  Boolean    @default(true) // carrinho ativo ou finalizado
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id             String   @id @default(uuid())
  cartId         String
  cart           Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  variationId    String?  // nullable porque nem todo produto tem variação
  variation      ProductVariation? @relation(fields: [variationId], references: [id])
  quantity       Int      @default(1)
  unitPrice      Float    // preço no momento da adição (snapshot)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([cartId, productId, variationId]) // evita duplicar mesmo item
}

model Coupon {
  id          String    @id @default(uuid())
  code        String    @unique // ex: "DESCONTO10"
  discount    Float     // porcentagem (0-100) ou valor fixo
  isPercentage Boolean  @default(true) // true = porcentagem, false = valor fixo
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  userId      String?   // nullable = cupom genérico, preenchido = cupom pessoal
  user        User?     @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
}
